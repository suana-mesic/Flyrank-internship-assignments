# Postgres (pgvector)
POSTGRES_USER=image_user
POSTGRES_PASSWORD=image_pass
POSTGRES_DB=imagedb

# Connection string read by the API (Npgsql)
ConnectionStrings__Images=Host=localhost;Port=5435;Username=image_user;Password=image_pass;Database=imagedb

# Vision / embedding provider key — filled in Phase 3 (e.g. OpenAI or Gemini)
AI__OllamaUrl=http://localhost:11434
AI__VisionModel=llava:13b
AI__EmbedModel=nomic-embed-text
AI__ConfidenceThreshold=0.6

Images__CorpusPath=path_to_images